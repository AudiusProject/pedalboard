{
  "name": "@pedalboard/relay",
  "version": "0.1.30",
  "private": true,
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch --preserveWatchOutput",
    "clean": "rm -rf dist",
    "dev": "concurrently \"npm:build:watch\" \"nodemon ./dist/index.js\"",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "lint": "tsc --noEmit && eslint \"src/**/*.ts*\"",
    "sandbox": "npx ts-node ./src/scripts/sandbox.ts",
    "start": "node ./dist/index.js",
    "test": "jest --detectOpenHandles"
  },
  "jest": {
    "preset": "jest-presets/jest/node"
  },
  "dependencies": {
    "@audius/sdk": "15.3.1",
    "@bufbuild/protobuf": "2.2.3",
    "@connectrpc/connect": "2.0.1",
    "@connectrpc/connect-node": "2.0.1",
    "@ethersproject/abstract-provider": "5.8.0",
    "@grpc/grpc-js": "1.13.4",
    "@grpc/proto-loader": "0.7.15",
    "@pedalboard/basekit": "*",
    "@pedalboard/logger": "*",
    "@pedalboard/storage": "*",
    "@types/compute-lcm": "1.1.3",
    "axios": "0.19.2",
    "body-parser": "1.20.3",
    "compute-lcm": "1.1.2",
    "copyfiles": "2.4.1",
    "cors": "2.8.5",
    "dotenv": "16.6.1",
    "envalid": "7.3.1",
    "eth-sig-util": "3.0.1",
    "ethers": "5.8.0",
    "express": "4.21.2",
    "http-status-codes": "2.3.0",
    "knex": "2.5.1",
    "morgan": "1.10.1",
    "rate-limiter-flexible": "2.4.2",
    "redis": "4.6.11",
    "uuid": "9.0.1",
    "web3": "1.8.2"
  },
  "devDependencies": {
    "@types/body-parser": "1.19.6",
    "@types/cors": "2.8.10",
    "@types/express": "4.17.23",
    "@types/jest": "26.0.24",
    "@types/morgan": "1.9.10",
    "@types/node": "15.14.9",
    "@types/redis": "4.0.11",
    "@types/supertest": "2.0.16",
    "@types/uuid": "9.0.8",
    "concurrently": "8.2.2",
    "esbuild": "0.14.38",
    "esbuild-register": "3.3.2",
    "eslint": "8.56.0",
    "eslint-config-custom-server": "*",
    "grpc_tools_node_protoc_ts": "5.3.3",
    "grpc-tools": "1.13.0",
    "jest": "26.6.3",
    "jest-presets": "*",
    "nodemon": "2.0.22",
    "supertest": "6.3.4",
    "tsconfig": "*",
    "typescript": "5.0.4"
  }
}
