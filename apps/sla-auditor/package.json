{
  "name": "@pedalboard/sla-auditor",
  "version": "0.0.30",
  "private": true,
  "description": "SLA auditor: checks discovery/content node versions vs chain minimums, proposes slash for non-compliance",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "lint": "eslint \"src/**/*.ts\"",
    "start": "node ./dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@audius/sdk-legacy": "6.0.23",
    "@pedalboard/basekit": "*",
    "@pedalboard/logger": "*",
    "@truffle/hdwallet-provider": "2.1.15",
    "bn.js": "5.2.1",
    "dotenv": "16.6.1",
    "semver": "7.7.4",
    "ts-results": "3.3.0",
    "web3": "1.10.4"
  },
  "devDependencies": {
    "@types/bn.js": "5.2.0",
    "@types/node": "18.19.79",
    "@types/semver": "7.7.1",
    "eslint": "8.56.0",
    "eslint-config-custom": "*",
    "tsconfig": "*",
    "typescript": "5.0.4"
  }
}
