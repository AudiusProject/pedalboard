    "ts-results": "^3.3.0",
    "web3": "^1.10.0"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.0",
    "@types/node": "^18.0.0",
    "@types/semver": "^7.5.0",
    "eslint": "8.56.0",
    "eslint-config-custom": "*",
    "tsconfig": "*",
    "typescript": "5.0.4"
