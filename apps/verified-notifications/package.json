{
  "name": "@pedalboard/verified-notifications",
  "version": "0.1.0",
  "description": "plugin for broadcasting verified notifications",
  "main": "dist/index.js",
  "private": true,
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "start": "node ./dist/index.js",
    "dev": "tsc --watch",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@audius/fixed-decimal": "*",
    "@pedalboard/basekit": "*",
    "@pedalboard/logger": "*",
    "@slack/web-api": "6.8.1",
    "dotenv": "16.0.3",
    "express": "4.18.2"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/node": "^18.0.0",
    "eslint": "8.56.0",
    "eslint-config-custom": "*",
    "tsconfig": "*",
    "typescript": "5.0.4"
  }
}
