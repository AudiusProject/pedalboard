    "start": "node ./dist/index.js",
    "test": "jest --detectOpenHandles"
  },
  "jest": {
    "preset": "jest-presets/jest/node"
  },
  "dependencies": {
    "@audius/sdk": "10.0.0",
    "@pedalboard/basekit": "*",
    "@pedalboard/logger": "*",
    "@pedalboard/storage": "*",
    "@slack/bolt": "3.22.0",
    "@slack/web-api": "6.13.0",
    "ascii-table3": "0.8.2",
    "cors": "2.8.5",
    "dotenv": "16.6.1",
    "express": "4.17.1",
    "knex": "2.5.1",
    "moment": "2.30.1",
    "morgan": "1.10.1",
    "node-cron": "3.0.3",
    "ts-results": "3.3.0"
  },
  "devDependencies": {
    "@types/cors": "2.8.10",
    "@types/express": "4.17.12",
    "@types/jest": "26.0.24",
    "@types/morgan": "1.9.10",
    "@types/node": "15.14.9",
    "@types/node-cron": "3.0.11",
    "@types/node-fetch": "2.6.4",
    "@types/supertest": "2.0.16",
    "esbuild": "0.14.38",
    "esbuild-register": "3.3.2",
    "eslint": "8.56.0",
    "eslint-config-custom-server": "*",
    "jest": "26.6.3",
    "jest-presets": "*",
    "nodemon": "2.0.22",
