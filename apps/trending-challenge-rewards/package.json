{
  "name": "@pedalboard/trending-challenge-rewards",
  "version": "0.0.30",
  "private": true,
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "watch": "tsc --watch",
    "dev": "concurrently \"npm run watch\" \"npm run start\"",
